<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CU Dining Sign Up</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
      background-color: #A2A4A3;
    }
    .btn-cu {
      background-color: #CFB87C;
      color: black;
    }

    .btn-cu:hover {
    background-color: #bfa56a; 
    color: black; 
    }
  </style>
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar bg-black px-3">
    <img src="https://upload.wikimedia.org/wikipedia/en/thumb/5/5b/Colorado_Buffaloes_logo.svg/256px-Colorado_Buffaloes_logo.svg.png" height="40">
  </nav>

  <!-- Sign Up -->
  <div class="container d-flex justify-content-center align-items-center" style="height: 90vh;">
    <div class="card p-4 shadow" style="max-width: 400px; width: 100%;">

      <h3 class="text-center">Create Account</h3>
      <p class="text-center text-muted">Join Buff Bites</p>

      <form action="/register" method="POST">
        <input class="form-control mb-3" type="text" name="username" placeholder="Username" required>
        <input class="form-control mb-3" type="email" name="email" placeholder="Email" required>
        <input class="form-control mb-3" type="password" name="password" placeholder="Password" required>
        <input class="form-control mb-3" type="password" placeholder="Confirm Password" required>

        <button class="btn btn-cu w-100">Sign Up</button>
      </form>

      <div class="text-center mt-3">
        <small>Already have an account?</small><br>
        <a href="/login" style="color:#CFB87C;">Login</a>
      </div>

    </div>
  </div>

</body>
</html>
