<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CU Dining Sign Up</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/resources/css/style.css">
  <style>
    .btn-cu { background-color: #CFB87C; color: black; }
    .btn-cu:hover { background-color: #bfa56a; color: black; }
    .form-error { color: #bf1c04; }
    .requirement { font-size: 0.8rem; }
    .requirement.met { color: green; }
    .requirement.unmet { color: #bf1c04; }
  </style>
</head>
<body>

  <!-- Navigation Bar -->
  <nav class="navbar bg-black px-3">
    <img src="../../resources/img/BuffBitesLogo.png" height="40">
  </nav>

  <div class="container d-flex justify-content-center align-items-center" style="height: 90vh;">
    <div class="card p-4 shadow" style="max-width: 400px; width: 100%;">

      <h3 class="text-center">Create Account</h3>
      <p class="text-center text-muted">Join Buff Bites</p>

      <form action="/register" method="POST" onsubmit="return confirmPassword(event, 'password', 'confirm-password', 'match-error') && validatePasswordStrength('password', 'strength-error')">
        <input class="form-control mb-3" type="text" name="username" placeholder="Username" required>
        <input class="form-control mb-3" type="email" name="email" placeholder="Email" required>
        <input class="form-control mb-2" type="password" name="password" placeholder="Password" id="password" required oninput="checkRequirements(this.value)">

        <!-- Live password requirements -->
        <div class="mb-2 ps-1">
          <div id="req-length" class="requirement unmet">✗ At least 8 characters</div>
          <div id="req-upper" class="requirement unmet">✗ One uppercase letter</div>
          <div id="req-lower" class="requirement unmet">✗ One lowercase letter</div>
          <div id="req-digit" class="requirement unmet">✗ One number</div>
        </div>

        <div id="strength-error" class="form-error mb-2" style="display: none;"></div>

        <input class="form-control mb-3" type="password" placeholder="Confirm Password" id="confirm-password" required>
        <div id="match-error" class="form-error mb-3" style="display: none;">Hidden</div>

        <button class="btn btn-cu w-100" type="submit">Sign Up</button>
      </form>

      <div class="text-center mt-3">
        <small>Already have an account?</small><br>
        <a href="/login" style="color:#CFB87C;">Login</a>
      </div>

    </div>
  </div>

  <script src="../../resources/js/script.js"></script>
  <script>
    function checkRequirements(value) {
      document.getElementById('req-length').className = 'requirement ' + (value.length >= 8 ? 'met' : 'unmet');
      document.getElementById('req-length').textContent = (value.length >= 8 ? '✓' : '✗') + ' At least 8 characters';

      document.getElementById('req-upper').className = 'requirement ' + (/[A-Z]/.test(value) ? 'met' : 'unmet');
      document.getElementById('req-upper').textContent = (/[A-Z]/.test(value) ? '✓' : '✗') + ' One uppercase letter';

      document.getElementById('req-lower').className = 'requirement ' + (/[a-z]/.test(value) ? 'met' : 'unmet');
      document.getElementById('req-lower').textContent = (/[a-z]/.test(value) ? '✓' : '✗') + ' One lowercase letter';

      document.getElementById('req-digit').className = 'requirement ' + (/\d/.test(value) ? 'met' : 'unmet');
      document.getElementById('req-digit').textContent = (/\d/.test(value) ? '✓' : '✗') + ' One number';
    }
  </script>
</body>
</html>