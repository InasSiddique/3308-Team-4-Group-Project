<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>C4C Dining Menu — CU Boulder</title>
		<link rel="stylesheet" href="https://use.typekit.net/nph0crg.css">
		<link rel="stylesheet" href="../../resources/css/style.css">
    <link rel="stylesheet" href="../../resources/css/home.css">
	</head>
	<body>
		<div class="wrap">

			<!-- ── Top Navigation ── -->
			<nav class="top-nav" aria-label="Site navigation">
				<div class="logo">
					<svg width="40" height="40" viewBox="0 0 42 42" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
						<circle cx="21" cy="21" r="20" fill="#CFB87C"/>
						<text x="21" y="28" text-anchor="middle" font-size="19" font-weight="900" fill="#000" font-family="Helvetica Neue, sans-serif">CU</text>
					</svg>
					<div class="logo-text">
						<span class="univ">University of Colorado</span>
						<span class="campus">BOULDER</span>
					</div>
				</div>
				<button class="hamburger" aria-label="Open menu" aria-expanded="false">
					<span></span><span></span><span></span>
				</button>
			</nav>
			<div class="gold-bar" role="presentation"></div>

			<!-- ── BuffBites Hero ── -->
      <section class="buffbites" aria-label="BuffBites dining location">
				<div class="buffbites-overlay" aria-hidden="true"></div>
				<svg class="buffbites-bg-svg" viewBox="0 0 980 200" preserveAspectRatio="xMidYMid slice" aria-hidden="true" focusable="false">
					<rect x="340" y="20" width="300" height="180" rx="150" fill="#CFB87C"/>
					<rect x="390" y="0" width="200" height="200" rx="100" fill="#CFB87C"/>
					<line x1="490" y1="200" x2="490" y2="0" stroke="#CFB87C" stroke-width="3"/>
					<line x1="340" y1="200" x2="490" y2="20" stroke="#CFB87C" stroke-width="2"/>
					<line x1="640" y1="200" x2="490" y2="20" stroke="#CFB87C" stroke-width="2"/>
				</svg>
				<div class="buffbites-content">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#CFB87C" stroke-width="2.5" aria-hidden="true" focusable="false">
						<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
						<circle cx="12" cy="9" r="2.5"/>
					</svg>
          <div>
            <h1 id="location-header" class="buffbites-title cursor-pointer noselect">Loading Location...</h1>
            <div id="location-select" class="location-select d-none">Loading Locations</div>
          </div>
					<span class="buffbites-badge" id="statusBadge">Closed</span>
					<span class="buffbites-badge" style="display: none;" id="openNowBadge">Open Now</span>
					<div class="buffbites-icons" aria-hidden="true">
						<div class="buffbites-icon" title="Hours">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#CFB87C" stroke-width="2">
								<circle cx="12" cy="12" r="10"/>
								<polyline points="12 6 12 12 16 14"/>
							</svg>
						</div>
					</div>
				</div>
			</section>

			<!-- ── Station Tabs ── -->
			<nav class="station-tabs" id="stationTabs" aria-label="Dining stations" role="tablist"></nav>

			<!-- ── Date Navigation ── -->
			<div class="date-nav" aria-label="Week navigation">
				<div class="date-left">
					<button class="period-btn">Daily ▾</button>
					<div class="date-input-wrap" id="dateInputDisplay">
						<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#CFB87C" stroke-width="2" aria-hidden="true">
							<rect x="3" y="4" width="18" height="18" rx="2"/>
							<line x1="16" y1="2" x2="16" y2="6"/>
							<line x1="8" y1="2" x2="8" y2="6"/>
							<line x1="3" y1="10" x2="21" y2="10"/>
						</svg>
						<span id="selectedDateDisplay"></span>
					</div>
				</div>
				<div class="date-range">
					<button class="arrow-btn" id="prevWeek" aria-label="Previous week">‹</button>
					<span id="dateRangeLabel"></span>
					<button class="arrow-btn" id="nextWeek" aria-label="Next week">›</button>
				</div>
        <div class="date-right">
        <span>
          <button id="filter-button" class="filter-btn" aria-label="Filter menu items">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#565A5C" stroke-width="2" aria-hidden="true">
              <line x1="4" y1="6" x2="20" y2="6"/>
              <line x1="8" y1="12" x2="16" y2="12"/>
              <line x1="11" y1="18" x2="13" y2="18"/>
            </svg>
            Filters
          </button>
            <div id="filter-menu" class="filter-menu d-none"></div>
        </span>
        <input id="item-search" class="input-text w-50" aria-label="Search menu items" autocomplete="off" placeholder="Search items"></input>
      </div>
			</div>

			<!-- ── Week Header ── -->
			<div class="week-header" id="weekHeader" role="group" aria-label="Select a day"></div>

			<!-- ── Menu Content ── -->
			<div class="menu-content" id="menuContent"></div>

			<!-- ── Footer ── -->
			<footer class="allergen-footer">
				<div class="footer-top">
					<svg width="38" height="38" viewBox="0 0 42 42" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
						<circle cx="21" cy="21" r="20" fill="#CFB87C"/>
						<text x="21" y="28" text-anchor="middle" font-size="19" font-weight="900" fill="#000" font-family="Helvetica Neue, sans-serif">CU</text>
					</svg>
					<div class="footer-logo-text">
						<div class="univ">University of Colorado</div>
						<div class="campus">BOULDER</div>
					</div>
				</div>
				<p>
					Note about allergens: Please be aware that due to the nature of a self-serve atmosphere,
					and the preparation of food items in a shared kitchen, there is a chance for cross-contact
					of gluten, eggs, fish, milk, peanuts, sesame, shellfish, soy, tree nuts and wheat.
					CU Boulder Campus Dining &amp; Hospitality makes every effort to thoroughly train staff
					on the importance of avoiding cross-contact with allergenic foods and accurately labeling
					food allergens in each dining hall and retail food venue. This information is based entirely
					on information provided by ingredient manufacturers and suppliers.
				</p>
				<div class="footer-divider" role="separator"></div>
				<p class="footer-usda">
					<a href="https://www.usda.gov" target="_blank" rel="noopener">
						USDA is an equal opportunity provider, employer, and lender.
					</a>
				</p>
				<nav class="footer-links" aria-label="Footer links">
					<a href="https://www.colorado.edu/privacy" target="_blank" rel="noopener">University of Colorado Privacy Notice</a>
					&nbsp;|&nbsp;
					<a href="#accessibility">Accessibility</a>
					&nbsp;|&nbsp;
					<a href="#privacy">Privacy Policy</a>
					&nbsp;|&nbsp;
					<a href="#terms">Terms of Use</a>
				</nav>
			</footer>
		</div><!-- /.wrap -->

		<script src="../../resources/js/home.js"></script>
	</body>
</html>
